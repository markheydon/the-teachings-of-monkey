{
  "name": "Teachings of Monkey",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "containerEnv": {
    "HUGO_VERSION": "0.152.2",
    "DART_SASS_VERSION": "1.93.3"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "files.eol": "\n"
      },
      "extensions": [
        "budparr.language-hugo-vscode",
        "yzhang.markdown-all-in-one"
      ]
    }
  },
  "postCreateCommand": "chmod +x scripts/install-toolchain.sh && scripts/install-toolchain.sh && grep -q 'PATH=\"$HOME/.local/dart-sass:$HOME/.local/hugo:$PATH\"' ~/.bashrc || echo 'export PATH=\"$HOME/.local/dart-sass:$HOME/.local/hugo:$PATH\"' >> ~/.bashrc",
  "postStartCommand": "export PATH=\"$HOME/.local/dart-sass:$HOME/.local/hugo:$PATH\" && hugo version && sass --version",
  "remoteUser": "vscode"
}
